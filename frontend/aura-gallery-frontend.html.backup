        <div style="font-size:2rem;margin-bottom:0.5rem">📱</div>
        <div style="font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--grey);margin-bottom:0.3rem">UPI</div>
        <div style="font-size:0.65rem;color:var(--gold)">Google Pay, PhonePe</div>
      </div>

      <!-- Net Banking -->
      <div class="payment-method" onclick="selectPaymentMethod('netbanking')" style="padding:1.5rem;border:1px solid rgba(201,168,76,0.2);cursor:pointer;transition:all 0.3s;border-radius:4px">
        <div style="font-size:2rem;margin-bottom:0.5rem">🌐</div>
        <div style="font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--grey);margin-bottom:0.3rem">Net Banking</div>
        <div style="font-size:0.65rem;color:var(--gold)">All Banks</div>
      </div>

      <!-- Digital Wallet -->
      <div class="payment-method" onclick="selectPaymentMethod('wallet')" style="padding:1.5rem;border:1px solid rgba(201,168,76,0.2);cursor:pointer;transition:all 0.3s;border-radius:4px">
        <div style="font-size:2rem;margin-bottom:0.5rem">👛</div>
        <div style="font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--grey);margin-bottom:0.3rem">E-Wallet</div>
        <div style="font-size:0.65rem;color:var(--gold)">PayTM, Amazon Pay</div>
      </div>

      <!-- Bank Transfer -->
      <div class="payment-method" onclick="selectPaymentMethod('transfer')" style="padding:1.5rem;border:1px solid rgba(201,168,76,0.2);cursor:pointer;transition:all 0.3s;border-radius:4px">
        <div style="font-size:2rem;margin-bottom:0.5rem">🏧</div>
        <div style="font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--grey);margin-bottom:0.3rem">Bank Transfer</div>
        <div style="font-size:0.65rem;color:var(--gold)">NEFT, RTGS, IMPS</div>
      </div>
    </div>

    <div style="background:rgba(201,168,76,0.08);padding:1rem;border-radius:4px;margin:2rem 0;font-size:0.7rem;color:var(--grey);line-height:1.6;letter-spacing:0.05em">
      ✓ Your payment is 100% secure and encrypted<br>
      ✓ Your card/bank details are never stored<br>
      ✓ Instant transaction confirmation
    </div>

    <div id="payment-error" style="color:#e06060;font-size:0.7rem;margin-bottom:1rem;min-height:1rem"></div>
  </div>
</div>

<script>
// ═══════════════════════════════════════
// API CONFIGURATION
// ═══════════════════════════════════════
const API_BASE = 'http://localhost:8080/api';

function getToken() { return localStorage.getItem('aura_token'); }
function setToken(token) { localStorage.setItem('aura_token', token); }
function clearToken() { localStorage.removeItem('aura_token'); }

// ═══════════════════════════════════════
// STATE
// ═══════════════════════════════════════
let users = [];
let artworks = [];
let currentUser = JSON.parse(localStorage.getItem('aura_current') || 'null');
let cart = JSON.parse(localStorage.getItem('aura_cart') || '[]');
let currentArtwork = null;
let currentFilter = 'all';
let viewerMode = 'rotate';
let currentEnv = 'gallery';
let apiConnectionFailed = false;
let retryAttempts = 0;
const MAX_RETRY_ATTEMPTS = 3;

// 3D
let scene, camera, renderer, frame;
let painting, paintingMesh, frameMesh;
let isDragging = false, prevMouse = {x:0,y:0};
let targetRot = {x:0,y:0}, currentRot = {x:0,y:0};
let envObjects = [];
let ambientLight, spotLight, fillLight, envLight;

// ═══════════════════════════════════════
// DEFAULT ARTWORKS
// ═══════════════════════════════════════
function getDefaultArtworks() {
  return [
    { id:1, title:'Crimson Reverie', artist:'Elena Voss', category:'Abstract', price:4800, medium:'Oil on Canvas', description:'A passionate exploration of colour and form.', sold:false, img:null },
    { id:2, title:'The Golden Hour', artist:'Marcus Thein', category:'Landscape', price:3200, medium:'Watercolour', description:'Dusk over the Amalfi coast.', sold:false, img:null },
    { id:3, title:'Inner Silence', artist:'Yuki Tanaka', category:'Portrait', price:5600, medium:'Charcoal & Pastel', description:'A meditation on solitude.', sold:false, img:null },
    { id:4, title:'Fractured Light', artist:'Amara Osei', category:'Abstract', price:7200, medium:'Acrylic on Panel', description:'Light refracted through geometric forms.', sold:true, img:null },
    { id:5, title:'Terra Memoria', artist:'Luisa Ferreira', category:'Landscape', price:2800, medium:'Mixed Media', description:'Memory of the Amazonian highlands.', sold:false, img:null },
    { id:6, title:'Algorithm Dreams', artist:'Kai Brennan', category:'Digital', price:1800, medium:'Digital Print', description:'Where code becomes canvas.', sold:false, img:null },
    { id:7, title:'The Watcher', artist:'Sofia Melis', category:'Portrait', price:9500, medium:'Oil on Linen', description:'A gaze that spans centuries.', sold:false, img:null },
    { id:8, title:'Void Form #3', artist:'David Nkosi', category:'Sculpture', price:12000, medium:'Bronze Cast', description:'Negative space as primary medium.', sold:false, img:null },
  ];
}

// ═══════════════════════════════════════
// HERO CANVAS (particle field)
// ═══════════════════════════════════════
(function initHeroCanvas() {
  const c = document.getElementById('hero-canvas');
  const ctx = c.getContext('2d');
  let W, H, pts;
  function resize() {
    W = c.width = innerWidth; H = c.height = innerHeight;
    pts = Array.from({length:80}, () => ({
      x: Math.random()*W, y: Math.random()*H,
      vx:(Math.random()-0.5)*0.3, vy:(Math.random()-0.5)*0.3,
      r: Math.random()*1.5+0.5
    }));
  }
  function draw() {
    ctx.clearRect(0,0,W,H);
    ctx.fillStyle='rgba(13,11,8,0.6)'; ctx.fillRect(0,0,W,H);
    pts.forEach(p => {
      p.x+=p.vx; p.y+=p.vy;
      if(p.x<0||p.x>W) p.vx*=-1;
      if(p.y<0||p.y>H) p.vy*=-1;
      ctx.beginPath(); ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
      ctx.fillStyle='rgba(201,168,76,0.4)'; ctx.fill();
    });
    pts.forEach((a,i) => pts.slice(i+1).forEach(b => {
      const d=Math.hypot(a.x-b.x,a.y-b.y);
      if(d<120) {
        ctx.beginPath(); ctx.moveTo(a.x,a.y); ctx.lineTo(b.x,b.y);
        ctx.strokeStyle=`rgba(201,168,76,${0.12*(1-d/120)})`; ctx.lineWidth=0.5; ctx.stroke();
      }
    }));
    requestAnimationFrame(draw);
  }
  resize(); window.addEventListener('resize', resize); draw();
})();

// ═══════════════════════════════════════
// GALLERY
// ═══════════════════════════════════════
async function renderGallery() {
  try {
    const url = currentFilter === 'all' 
      ? `${API_BASE}/artworks` 
      : `${API_BASE}/artworks?category=${currentFilter}`;
    const res = await fetch(url);
    if(!res.ok) throw new Error('Failed to fetch artworks');
    const data = await res.json();
    artworks = data || [];
    
    // Cache successfully fetched artworks
    if(artworks.length > 0) {
      localStorage.setItem('aura_artworks', JSON.stringify(artworks));
      apiConnectionFailed = false;
      retryAttempts = 0;
    }
    
    renderGalleryGrid(artworks);
  } catch(e) { 
    console.error('Gallery load error:', e);
    
    // Try to load from cache
    const cached = localStorage.getItem('aura_artworks');
    if(cached) {
      try {
        const cachedArtworks = JSON.parse(cached);
        if(cachedArtworks.length > 0) {
          console.log('Loading artworks from cache...');
          artworks = cachedArtworks;
          apiConnectionFailed = true;
          renderGalleryGrid(artworks);
          showToast('⚠ Loading from cache (offline). Some features may be limited.');
          // Attempt reconnection
          attemptReconnection();
          return;
        }
      } catch(cacheErr) {
        console.error('Cache error:', cacheErr);
      }
    }
    
    // Fallback to default artworks
    artworks = getDefaultArtworks();
    apiConnectionFailed = true;
    renderGalleryGrid(artworks);
    showToast('⚠ Using fallback data. Backend is offline. Attempting to reconnect...');
    attemptReconnection();
  }
}

function renderGalleryGrid(list) {
  const grid = document.getElementById('gallery-grid');
  if(list.length === 0) {
    grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:3rem;color:var(--grey)">No artworks yet. Be the first to share your work!</div>';
    document.getElementById('stat-artworks').textContent = '0';
    return;
  }
  grid.innerHTML = list.map(a => `
    <div class="artwork-card" data-id="${a.id}">
      <div class="artwork-canvas-wrap">
        ${a.imageUrl
          ? `<img class="artwork-img" src="http://localhost:8080${a.imageUrl}" alt="${a.title}" onerror="this.src='https://via.placeholder.com/400x300'">`
          : `<canvas id="art-${a.id}" width="400" height="300"></canvas>`}
        <div class="artwork-overlay">
          <div class="overlay-btns">
            <button class="overlay-btn view" onclick="openViewer(${a.id})">View in 3D</button>
            ${!a.sold ? `<button class="overlay-btn cart" onclick="addToCart(${a.id},event)">+ Cart</button>` : ''}
          </div>
        </div>
      </div>
      <div class="artwork-info">
        <div class="artwork-title">${a.title}</div>
        <div class="artwork-artist">by ${a.artistName}</div>
        <div class="artwork-footer">
          <span class="artwork-price">${a.sold ? 'Sold' : '₹'+a.price.toLocaleString()}</span>
          <span class="artwork-cat">${a.category}</span>
        </div>
      </div>
    </div>
  `).join('');
  // Draw procedural art
  list.forEach(a => { if (!a.imageUrl) setTimeout(() => drawProceduralArt(a), 50); });
  document.getElementById('stat-artworks').textContent = artworks.length;
}

// ── RECONNECTION LOGIC ────────────────
function attemptReconnection() {
  if(retryAttempts >= MAX_RETRY_ATTEMPTS) {
    console.log('Max retry attempts reached. Manual reconnection required.');
    return;
  }
  
  // Retry after exponential backoff: 5s, 15s, 30s
  const delays = [5000, 15000, 30000];
  const delay = delays[retryAttempts];
  
  setTimeout(() => {
    retryAttempts++;
    console.log(`Attempting reconnection... (${retryAttempts}/${MAX_RETRY_ATTEMPTS})`);
    renderGallery();
  }, delay);
}

function filterGallery(cat, btn) {
  currentFilter = cat;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderGallery();
}

// ═══════════════════════════════════════
// PROCEDURAL ART
// ═══════════════════════════════════════
function drawProceduralArt(artwork) {
  const c = document.getElementById('art-'+artwork.id);
  if (!c) return;
  const ctx = c.getContext('2d');
  const W = c.width, H = c.height;
  const seed = artwork.id * 137;
  const rng = (n=1) => { let x=Math.sin(seed+rng._i++)*10000; return (x-Math.floor(x))*n; };
  rng._i = 0;

  switch(artwork.category) {
    case 'Abstract': drawAbstract(ctx,W,H,rng); break;
    case 'Landscape': drawLandscape(ctx,W,H,rng); break;
    case 'Portrait': drawPortrait(ctx,W,H,rng); break;
    case 'Sculpture': drawSculpture(ctx,W,H,rng); break;
    case 'Digital': drawDigital(ctx,W,H,rng); break;
    default: drawAbstract(ctx,W,H,rng);
  }
  addGrain(ctx,W,H);
}

function drawAbstract(ctx,W,H,rng) {
  const palettes = [
    ['#8b3a2a','#c9a84c','#3a2a5a','#2a4a3a'],
    ['#1a3a5a','#c9a84c','#8b2a2a','#4a2a1a'],
    ['#2a4a2a','#c9a84c','#3a2a4a','#5a3a1a'],
  ];
  const pal = palettes[Math.floor(rng(3))];
  ctx.fillStyle = '#0d0b08'; ctx.fillRect(0,0,W,H);
  for(let i=0;i<40;i++) {
    ctx.save();
    ctx.globalAlpha = rng(0.7)+0.1;
    ctx.fillStyle = pal[Math.floor(rng(pal.length))];
    ctx.translate(rng(W), rng(H));
    ctx.rotate(rng(Math.PI*2));
    if(rng()<0.5) {
      ctx.beginPath();
      ctx.ellipse(0,0,rng(W/3)+20,rng(H/4)+10,0,0,Math.PI*2);
      ctx.fill();
    } else {
      ctx.fillRect(-rng(W/4)-10,-rng(H/5)-10,rng(W/3)+20,rng(H/3)+20);
    }
    ctx.restore();
  }
  ctx.globalAlpha = 0.15;
  ctx.strokeStyle = '#c9a84c'; ctx.lineWidth = 1;
  for(let i=0;i<8;i++) {
    ctx.beginPath(); ctx.moveTo(rng(W),rng(H)); ctx.lineTo(rng(W),rng(H)); ctx.stroke();
  }
  ctx.globalAlpha = 1;
}

function drawLandscape(ctx,W,H,rng) {
  const skies = [['#1a0a2a','#4a2a8a'],['#0a1a3a','#8b3a2a'],['#0a2a1a','#2a4a6a']];
  const sky = skies[Math.floor(rng(3))];
  const grad = ctx.createLinearGradient(0,0,0,H);
  grad.addColorStop(0, sky[0]); grad.addColorStop(1, sky[1]);
  ctx.fillStyle = grad; ctx.fillRect(0,0,W,H);
  const horizon = H*0.45 + rng(H*0.15);
  for(let layer=0; layer<3; layer++) {
    const y = horizon + layer*H*0.08;
    const darkness = layer*40;
    ctx.fillStyle = `rgb(${20+darkness},${15+darkness},${10+darkness})`;
    ctx.beginPath(); ctx.moveTo(0,H);
    for(let x=0;x<=W;x+=10) ctx.lineTo(x, y + Math.sin(x*0.02+layer)*30 + rng(20)-10);
    ctx.lineTo(W,H); ctx.closePath(); ctx.fill();
  }
  ctx.fillStyle = `rgba(201,168,76,0.7)`;
  const sunX=rng(W*0.6)+W*0.2, sunY=rng(horizon*0.5)+20;
  const sunR = ctx.createRadialGradient(sunX,sunY,0,sunX,sunY,W*0.3);
  sunR.addColorStop(0,'rgba(201,168,76,0.5)'); sunR.addColorStop(1,'transparent');
  ctx.fillStyle=sunR; ctx.fillRect(0,0,W,H);
  ctx.beginPath(); ctx.arc(sunX,sunY,rng(15)+8,0,Math.PI*2);
  ctx.fillStyle='rgba(255,220,100,0.8)'; ctx.fill();
}

function drawPortrait(ctx,W,H,rng) {
  const bg = ctx.createLinearGradient(0,0,W,H);
  bg.addColorStop(0,'#1a1208'); bg.addColorStop(1,'#0d0b06');
  ctx.fillStyle=bg; ctx.fillRect(0,0,W,H);
  const cx=W/2, cy=H*0.42;
  const g = ctx.createRadialGradient(cx,cy,10,cx,cy,H*0.4);
  g.addColorStop(0,'rgba(201,168,76,0.08)'); g.addColorStop(1,'transparent');
  ctx.fillStyle=g; ctx.fillRect(0,0,W,H);
  ctx.fillStyle='#2a1e12';
  ctx.beginPath(); ctx.ellipse(cx,cy+H*0.06,W*0.22,H*0.32,0,0,Math.PI*2); ctx.fill();
  ctx.fillStyle='#1e1608';
  ctx.beginPath(); ctx.ellipse(cx,cy,W*0.18,W*0.2,0,0,Math.PI*2); ctx.fill();
  ctx.fillStyle='rgba(201,168,76,0.5)';
  ctx.beginPath(); ctx.arc(cx-W*0.05,cy-H*0.03,3,0,Math.PI*2); ctx.fill();
  ctx.beginPath(); ctx.arc(cx+W*0.05,cy-H*0.03,3,0,Math.PI*2); ctx.fill();
  ctx.strokeStyle='rgba(201,168,76,0.15)'; ctx.lineWidth=1;
  for(let i=0;i<5;i++){
    ctx.beginPath(); ctx.arc(cx,cy,W*0.1*i,0,Math.PI*2); ctx.stroke();
  }
}

function drawSculpture(ctx,W,H,rng) {
  ctx.fillStyle='#141210'; ctx.fillRect(0,0,W,H);
  const cx=W/2, cy=H/2;
  const g=ctx.createRadialGradient(cx-W*0.1,cy-H*0.1,10,cx,cy,W*0.5);
  g.addColorStop(0,'rgba(201,168,76,0.3)'); g.addColorStop(0.5,'rgba(100,80,40,0.1)'); g.addColorStop(1,'transparent');
  ctx.fillStyle=g; ctx.fillRect(0,0,W,H);
  ctx.strokeStyle='rgba(201,168,76,0.6)'; ctx.lineWidth=1.5;
  for(let i=0;i<6;i++) {
    ctx.save(); ctx.translate(cx,cy); ctx.rotate(i*Math.PI/3 + rng(0.3));
    ctx.scale(1+rng(0.3),0.8+rng(0.4));
    ctx.beginPath(); ctx.ellipse(0,0,W*0.15+rng(W*0.1),H*0.2+rng(H*0.1),0,0,Math.PI*2);
    ctx.globalAlpha=0.4+rng(0.3); ctx.stroke(); ctx.restore();
  }
  ctx.globalAlpha=1;
  ctx.strokeStyle='rgba(201,168,76,0.8)'; ctx.lineWidth=2;
  ctx.beginPath(); ctx.arc(cx,cy,W*0.08,0,Math.PI*2); ctx.stroke();
}

function drawDigital(ctx,W,H,rng) {
  ctx.fillStyle='#060810'; ctx.fillRect(0,0,W,H);
  for(let y=0;y<H;y+=4) {
    ctx.fillStyle=`rgba(0,${Math.floor(rng(80))+20},${Math.floor(rng(120))+40},${rng(0.08)+0.02})`;
    ctx.fillRect(0,y,W,2);
  }
  ctx.font='10px monospace'; ctx.fillStyle='rgba(0,255,120,0.15)';
  for(let i=0;i<30;i++) {
    ctx.fillText(Math.random()<0.5?'0':'1', rng(W), rng(H));
  }
  const colors=['rgba(0,255,180,','rgba(201,168,76,','rgba(180,0,255,'];
  for(let i=0;i<20;i++) {
    ctx.strokeStyle=colors[Math.floor(rng(3))]+`${rng(0.5)+0.1})`;
    ctx.lineWidth=rng(2)+0.5;
    ctx.beginPath(); ctx.moveTo(rng(W),rng(H));
    ctx.bezierCurveTo(rng(W),rng(H),rng(W),rng(H),rng(W),rng(H));
    ctx.stroke();
  }
  ctx.fillStyle='rgba(201,168,76,0.6)';
  ctx.beginPath(); ctx.arc(W/2+rng(W*0.2)-W*0.1,H/2+rng(H*0.2)-H*0.1,rng(20)+5,0,Math.PI*2); ctx.fill();
}

function addGrain(ctx,W,H) {
  const imgData = ctx.getImageData(0,0,W,H);
  const d=imgData.data;
  for(let i=0;i<d.length;i+=4) {
    const n=(Math.random()-0.5)*15;
    d[i]+=n; d[i+1]+=n; d[i+2]+=n;
  }
  ctx.putImageData(imgData,0,0);
}

// ═══════════════════════════════════════
// 3D VIEWER
// ═══════════════════════════════════════
function openViewer(id) {
  currentArtwork = artworks.find(a=>a.id===id);
  if(!currentArtwork) return;
  document.getElementById('viewer-modal').classList.add('open');
  document.getElementById('v-title').textContent = currentArtwork.title;
  document.getElementById('v-meta-title').textContent = currentArtwork.title;
  document.getElementById('v-meta-sub').textContent = `${currentArtwork.artistName} · ${currentArtwork.medium}`;
  document.getElementById('v-meta-price').textContent = currentArtwork.sold ? 'Sold' : `₹${currentArtwork.price.toLocaleString()}`;
  // Reset hint
  const hint = document.getElementById('viewer-hint');
  hint.style.animation='none'; hint.offsetHeight; hint.style.animation='hint-fade 3s forwards';
  initThreeScene();
}

function closeViewer() {
  document.getElementById('viewer-modal').classList.remove('open');
  if(renderer) { cancelAnimationFrame(frame); renderer.dispose(); renderer=null; scene=null; }
}

function initThreeScene() {
  if(renderer) { cancelAnimationFrame(frame); renderer.dispose(); renderer=null; }
  const canvas = document.getElementById('viewer-canvas');
  const W=canvas.clientWidth, H=canvas.clientHeight;

  scene = new THREE.Scene();
  camera = new THREE.PerspectiveCamera(50, W/H, 0.1, 100);
  camera.position.set(0, 0, 5);

  renderer = new THREE.WebGLRenderer({ canvas, antialias:true, alpha:true });
  renderer.setSize(W, H);
  renderer.setPixelRatio(Math.min(devicePixelRatio,2));
  renderer.shadowMap.enabled = true;
  renderer.shadowMap.type = THREE.PCFSoftShadowMap;

  currentRot = {x:0,y:0}; targetRot = {x:0,y:0};
  envObjects = [];

  buildEnvironment(currentEnv);
  buildPainting();
  setupLighting(currentEnv);
  setupViewerControls(canvas);
  animateViewer();
}

// ── ENVIRONMENTS ─────────────────────
const ENV_CONFIGS = {
  gallery: {
    bg: 0x1a1510,
    floor: { color: 0x2a2018, roughness: 0.8, metalness: 0.1 },
    walls: { color: 0x1e1a14 },
    ambient: { color: 0xfff8e8, intensity: 0.4 },
    spot: { color: 0xffe8b0, intensity: 2.5, pos: [2,4,2] },
    fill: { color: 0x3a3028, intensity: 0.5 },
    fog: { color: 0x1a1510, near: 8, far: 20 },
  },
  studio: {
    bg: 0x0f1420,
    floor: { color: 0x2a2a30, roughness: 0.9, metalness: 0.0 },
    walls: { color: 0x141820 },
    ambient: { color: 0xe0e8ff, intensity: 0.6 },
    spot: { color: 0xc0d8ff, intensity: 2.0, pos: [0,5,1] },
    fill: { color: 0x2030a0, intensity: 0.3 },
    fog: { color: 0x0f1420, near: 10, far: 22 },
  },
  outdoor: {
    bg: 0x4a8ab0,
    floor: { color: 0x3a5028, roughness: 1.0, metalness: 0.0 },
    walls: null,
    ambient: { color: 0xffffff, intensity: 1.0 },
    spot: { color: 0xfff0c0, intensity: 3.0, pos: [3,6,3] },
    fill: { color: 0xa0c8e0, intensity: 0.8 },
    fog: { color: 0x4a8ab0, near: 12, far: 30 },
  },
  museum: {
    bg: 0x18140e,
    floor: { color: 0x3a3020, roughness: 0.3, metalness: 0.3 },
    walls: { color: 0x2a2418 },
    ambient: { color: 0xfff0d0, intensity: 0.5 },
    spot: { color: 0xfff8e0, intensity: 3.0, pos: [0,5,2] },
    fill: { color: 0x4a3820, intensity: 0.4 },
    fog: { color: 0x18140e, near: 10, far: 25 },
  },
  night: {
    bg: 0x050510,
    floor: { color: 0x101020, roughness: 0.6, metalness: 0.4 },
    walls: { color: 0x080818 },
    ambient: { color: 0x2030a0, intensity: 0.2 },
    spot: { color: 0xc040ff, intensity: 2.5, pos: [-1,4,2] },
    fill: { color: 0x4000ff, intensity: 0.6 },
    fog: { color: 0x050510, near: 6, far: 18 },
  }
};

function buildEnvironment(envKey) {
  const cfg = ENV_CONFIGS[envKey];
  scene.background = new THREE.Color(cfg.bg);
  if(cfg.fog) scene.fog = new THREE.Fog(cfg.fog.color, cfg.fog.near, cfg.fog.far);
  else scene.fog = null;

  // Floor
  const floorGeo = new THREE.PlaneGeometry(20, 20);
  const floorMat = new THREE.MeshStandardMaterial({
    color: cfg.floor.color, roughness: cfg.floor.roughness, metalness: cfg.floor.metalness,
  });
  const floor = new THREE.Mesh(floorGeo, floorMat);
  floor.rotation.x = -Math.PI/2; floor.position.y = -2; floor.receiveShadow=true;
  scene.add(floor); envObjects.push(floor);

  if(envKey === 'outdoor') {
    // Sky dome
    const skyGeo = new THREE.SphereGeometry(20,16,16);
    const skyMat = new THREE.MeshBasicMaterial({
      color:0x4a8ab0, side:THREE.BackSide
    });
    const sky = new THREE.Mesh(skyGeo,skyMat);
    scene.add(sky); envObjects.push(sky);
    // Grass patches
    for(let i=0;i<6;i++) {
      const g=new THREE.Mesh(
        new THREE.BoxGeometry(0.1+Math.random()*0.3,0.4+Math.random()*0.5,0.05),
        new THREE.MeshStandardMaterial({color:0x2a5018})
      );
      g.position.set((Math.random()-0.5)*6, -1.8+g.scale.y*0.1, -2+Math.random()*-3);
      scene.add(g); envObjects.push(g);
    }
  }

  if(envKey === 'night') {
    // Stars
    const starGeo = new THREE.BufferGeometry();
    const starVerts = [];
    for(let i=0;i<500;i++) {
      starVerts.push((Math.random()-0.5)*40,(Math.random()+0.2)*10,(Math.random()-0.5)*40);
    }
    starGeo.setAttribute('position', new THREE.Float32BufferAttribute(starVerts,3));
    const stars = new THREE.Points(starGeo, new THREE.PointsMaterial({color:0xffffff,size:0.05}));
    scene.add(stars); envObjects.push(stars);
    // Neon strip light under painting
    const neon = new THREE.Mesh(
      new THREE.BoxGeometry(2.2,0.06,0.06),
      new THREE.MeshStandardMaterial({color:0xc040ff,emissive:0xc040ff,emissiveIntensity:3})
    );
    neon.position.set(0,-0.5,-1.8); scene.add(neon); envObjects.push(neon);
  }

  if(cfg.walls) {
    // Back wall
    const wallGeo = new THREE.PlaneGeometry(20,10);
    const wallMat = new THREE.MeshStandardMaterial({color:cfg.walls.color,roughness:0.9});
    const wall = new THREE.Mesh(wallGeo,wallMat);
    wall.position.set(0,3,-3); wall.receiveShadow=true;
    scene.add(wall); envObjects.push(wall);

    if(envKey==='gallery') {
      // Skirting
      const sk = new THREE.Mesh(
        new THREE.BoxGeometry(20,0.15,0.05),
        new THREE.MeshStandardMaterial({color:0xc9a84c,metalness:0.5,roughness:0.4})
      );
      sk.position.set(0,-2+0.075,-2.97); scene.add(sk); envObjects.push(sk);
    }
    if(envKey==='museum') {
      // Columns
      for(let x of [-3,3]) {
        const col = new THREE.Mesh(
          new THREE.CylinderGeometry(0.18,0.2,6,12),
          new THREE.MeshStandardMaterial({color:0x3a3020,roughness:0.4,metalness:0.2})
        );
        col.position.set(x,1,-2.5); col.castShadow=true;
        scene.add(col); envObjects.push(col);
      }
    }
  }

  // Easel for studio
  if(envKey==='studio') {
    const easelMat = new THREE.MeshStandardMaterial({color:0x5a3a18,roughness:0.9});
    [[0,-0.8],[0.3,-0.8],[-0.3,-0.8]].forEach(([ox,oz],i) => {
      const leg = new THREE.Mesh(new THREE.BoxGeometry(0.05,3,0.05), easelMat);
      leg.position.set(ox+2.2,-0.5,oz-1); leg.rotation.z=(i===0?0:i===1?0.25:-0.25);
      scene.add(leg); envObjects.push(leg);
    });
  }
}

function setupLighting(envKey) {
  // Remove old lights
  scene.children.filter(c=>c.isLight).forEach(l=>scene.remove(l));

  const cfg = ENV_CONFIGS[envKey];

  ambientLight = new THREE.AmbientLight(cfg.ambient.color, cfg.ambient.intensity);
  scene.add(ambientLight);

  spotLight = new THREE.SpotLight(cfg.spot.color, cfg.spot.intensity);
  spotLight.position.set(...cfg.spot.pos);
  spotLight.target.position.set(0,0,0);
  spotLight.castShadow = true;
  spotLight.shadow.mapSize.set(1024,1024);
  spotLight.angle = Math.PI/6; spotLight.penumbra = 0.3;
  scene.add(spotLight); scene.add(spotLight.target);

  fillLight = new THREE.DirectionalLight(cfg.fill.color, cfg.fill.intensity);
  fillLight.position.set(-3,2,3);
  scene.add(fillLight);

  if(envKey==='night') {
    const purple = new THREE.PointLight(0x8020ff,3,6);
    purple.position.set(-2,1,2); scene.add(purple);
  }
}

function buildPainting() {
  if(paintingMesh) scene.remove(paintingMesh);
  if(frameMesh) scene.remove(frameMesh);

  const AW = currentArtwork;
  const W=1.6, H=1.2;

  // Create texture from canvas
  let tex;
  if(AW.imageUrl) {
    const img = new Image();
    img.src = 'http://localhost:8080' + AW.imageUrl;
    img.crossOrigin = 'anonymous';
    tex = new THREE.Texture(img);
    img.onload = ()=>{ tex.needsUpdate=true; };
  } else {
    const offC = document.createElement('canvas');
    offC.width=400; offC.height=300;
    const ctx = offC.getContext('2d');
    const seed=AW.id*137;
    const rng=(n=1)=>{let x=Math.sin(seed+rng._i++)*10000;rng._i=rng._i||0;return(x-Math.floor(x))*n;};
    rng._i=0;
    switch(AW.category){
      case 'Landscape': drawLandscape(ctx,400,300,rng); break;
      case 'Portrait': drawPortrait(ctx,400,300,rng); break;
      case 'Sculpture': drawSculpture(ctx,400,300,rng); break;
      case 'Digital': drawDigital(ctx,400,300,rng); break;
      default: drawAbstract(ctx,400,300,rng);
    }
    addGrain(ctx,400,300);
    tex = new THREE.CanvasTexture(offC);
  }

  const paintGeo = new THREE.PlaneGeometry(W,H);
  const paintMat = new THREE.MeshStandardMaterial({
    map: tex, roughness: 0.85, metalness: 0.0,
    bumpScale: 0.01
  });
  paintingMesh = new THREE.Mesh(paintGeo, paintMat);
  paintingMesh.position.set(0,0,-1.99);
  paintingMesh.castShadow = true;
  scene.add(paintingMesh);

  // Gold frame
  const frameParts = [
    {s:[W+0.12,0.06,0.06],p:[0,H/2+0.03,0]},
    {s:[W+0.12,0.06,0.06],p:[0,-H/2-0.03,0]},
    {s:[0.06,H+0.06,0.06],p:[-W/2-0.03,0,0]},
    {s:[0.06,H+0.06,0.06],p:[W/2+0.03,0,0]},
  ];
  const frameMat = new THREE.MeshStandardMaterial({color:0xc9a84c,metalness:0.8,roughness:0.3});
  frameParts.forEach(f=>{
    const m=new THREE.Mesh(new THREE.BoxGeometry(...f.s),frameMat);
    m.position.set(f.p[0],f.p[1],-1.97); m.castShadow=true;
    scene.add(m);
  });

  // Label plaque
  const plaque = new THREE.Mesh(
    new THREE.BoxGeometry(0.5,0.08,0.02),
    new THREE.MeshStandardMaterial({color:0xc9a84c,metalness:0.7,roughness:0.3})
  );
  plaque.position.set(0,-H/2-0.15,-1.97);
  scene.add(plaque);
}

function animateViewer() {
  if(!renderer) return;
  frame = requestAnimationFrame(animateViewer);
  currentRot.x += (targetRot.x - currentRot.x)*0.06;
  currentRot.y += (targetRot.y - currentRot.y)*0.06;
  if(viewerMode==='rotate'&&!isDragging) targetRot.y += 0.003;
  scene.rotation.y = currentRot.y;
  scene.rotation.x = currentRot.x;
  renderer.render(scene,camera);
}

function setupViewerControls(canvas) {
  canvas.addEventListener('mousedown', e=>{ isDragging=true; prevMouse={x:e.clientX,y:e.clientY}; });
  canvas.addEventListener('mouseup', ()=>isDragging=false);
  canvas.addEventListener('mousemove', e=>{
    if(!isDragging) return;
    const dx=e.clientX-prevMouse.x, dy=e.clientY-prevMouse.y;
    if(viewerMode==='rotate'||viewerMode==='zoom') {
      targetRot.y += dx*0.005; targetRot.x += dy*0.003;
      targetRot.x = Math.max(-0.4,Math.min(0.4,targetRot.x));
    }
    prevMouse={x:e.clientX,y:e.clientY};
  });
  canvas.addEventListener('wheel', e=>{
    camera.position.z = Math.max(2,Math.min(10,camera.position.z+e.deltaY*0.01));
  });
  canvas.addEventListener('touchstart',e=>{ isDragging=true; prevMouse={x:e.touches[0].clientX,y:e.touches[0].clientY}; },{passive:true});
  canvas.addEventListener('touchend',()=>isDragging=false,{passive:true});
  canvas.addEventListener('touchmove',e=>{
    if(!isDragging) return;
    const dx=e.touches[0].clientX-prevMouse.x, dy=e.touches[0].clientY-prevMouse.y;
    targetRot.y+=dx*0.005; targetRot.x+=dy*0.003;
    prevMouse={x:e.touches[0].clientX,y:e.touches[0].clientY};
  },{passive:true});
}

function setViewerMode(mode,btn) {
  viewerMode=mode;
  document.querySelectorAll('.tool-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
}

function resetViewerCamera() {
  targetRot={x:0,y:0}; camera.position.set(0,0,5);
}

// ── ENVIRONMENT SWITCHING ─────────────
function switchEnvironment(envKey, btn) {
  if(envKey===currentEnv) return;
  const tr = document.getElementById('env-transition');
  tr.classList.add('fade-in');
  document.querySelectorAll('.env-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  setTimeout(()=>{
    currentEnv = envKey;
    // Remove env objects
    envObjects.forEach(o=>scene.remove(o));
    envObjects=[];
    buildEnvironment(envKey);
    setupLighting(envKey);
    tr.classList.remove('fade-in');
  }, 350);
  showToast(`Environment: <span class="toast-gold">${btn.querySelector('.env-name').textContent}</span>`);
}

// ═══════════════════════════════════════
// CART
// ═══════════════════════════════════════
function addToCart(id, e) {
  if(e) e.stopPropagation();
  if(!currentUser) { openAuth('login'); return; }
  const art = artworks.find(a=>a.id===id);
  if(!art || art.sold) return;
  if(cart.find(c=>c.id===id)) { showToast('Already in your collection'); return; }
  cart.push(art);
  saveCart();
  updateCartUI();
  showToast(`<span class="toast-gold">${art.title}</span> added to collection`);
}

function addViewerToCart() { if(currentArtwork) addToCart(currentArtwork.id); }

function removeFromCart(id) {
  cart=cart.filter(c=>c.id!==id);
  saveCart(); updateCartUI();
}

function purchaseViewer() {
  if(!currentUser) { closeViewer(); openAuth('login'); return; }
  if(!currentArtwork || currentArtwork.sold) return;
  currentArtwork.sold=true;
  saveArtworks();
  showToast(`🎉 <span class="toast-gold">${currentArtwork.title}</span> is now yours!`);
  document.getElementById('v-meta-price').textContent='Sold';
  renderGallery();
  closeViewer();
}

function confirmCheckout() {
  if(cart.length === 0) { showToast('Your collection is empty'); return; }
  const total = cart.reduce((s,c) => s + c.price, 0);
  // Show payment method selection modal instead of processing immediately
  document.getElementById('payment-modal').classList.add('open');
  document.getElementById('payment-error').textContent = '';
}

function closePaymentModal() {
  document.getElementById('payment-modal').classList.remove('open');
  document.getElementById('payment-error').textContent = '';
}

function selectPaymentMethod(method) {
  const total = cart.reduce((s,c) => s + c.price, 0);
  const methodNames = {
    'creditcard': 'Credit Card',
    'debitcard': 'Debit Card',
    'upi': 'UPI',
    'netbanking': 'Net Banking',
    'wallet': 'Digital Wallet',
    'transfer': 'Bank Transfer'
  };
  
  const methodName = methodNames[method] || method;
  const confirmed = confirm(
    `Confirm Payment\n\nPayment Method: ${methodName}\nAmount: ₹${total.toLocaleString()}\n\nProceed with payment?`
  );
  
  if(confirmed) {
    closePaymentModal();
    processCheckout(method);
  }
}

async function processCheckout(paymentMethod) {
  if(cart.length===0) return;
  if(apiConnectionFailed) { showToast('⚠ Backend is offline. Cannot process payment at this time.'); return; }
  try {
    showToast('Processing payment via ' + (paymentMethod || 'selected method') + '...');
    const artworkIds = cart.map(c => c.id);
    const res = await fetch(`${API_BASE}/orders/checkout`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': 'Bearer ' + getToken()
      },
      body: JSON.stringify({ artworkIds, paymentMethod: paymentMethod || 'card' })
    });
    const data = await res.json();
    if(!res.ok) { 
      showToast('Payment failed: ' + (data.message || 'Unknown error')); 
      console.error('Checkout error:', data);
      return; 
    }
    cart = [];
    saveCart();
    updateCartUI();
    toggleCart();
    renderGallery();
    showPaymentSuccess(paymentMethod);
  } catch(e) { 
    console.error('Checkout error:', e);
    showToast('Payment error: ' + e.message + ' (Backend may be offline)'); 
  }
}

function showPaymentSuccess(paymentMethod) {
  const methodNames = {
    'creditcard': 'Credit Card',
    'debitcard': 'Debit Card',
    'upi': 'UPI',
    'netbanking': 'Net Banking',
    'wallet': 'Digital Wallet',
    'transfer': 'Bank Transfer'
  };
  
  showToast(`✓ Payment via ${methodNames[paymentMethod] || 'Credit Card'} successful!`);
  // Could open a detailed receipt page here in future
}

function toggleCart() {
  document.getElementById('cart-sidebar').classList.toggle('open');
}

function updateCartUI() {
  const count = cart.length;
  document.getElementById('cart-count').textContent=count;
  const items=document.getElementById('cart-items');
  if(count===0) { items.innerHTML='<div class="empty-cart">Your collection is empty</div>'; }
  else items.innerHTML=cart.map(c=>`
    <div class="cart-item">
      <div class="cart-thumb" style="background:#1a1510;display:flex;align-items:center;justify-content:center;font-size:1.5rem">
        ${c.img?`<img src="${c.img}" style="width:100%;height:100%;object-fit:cover">`:'🖼'}
      </div>
      <div class="cart-item-info">
        <div class="cart-item-name">${c.title}</div>
        <div class="cart-item-price">₹${c.price.toLocaleString()}</div>
      </div>
      <button class="cart-remove" onclick="removeFromCart(${c.id})">✕</button>
    </div>
  `).join('');
  const total=cart.reduce((s,c)=>s+c.price,0);
  document.getElementById('cart-total').textContent='$'+total.toLocaleString();
  localStorage.setItem('aura_cart',JSON.stringify(cart));
}

function saveCart() { localStorage.setItem('aura_cart',JSON.stringify(cart)); }

// ═══════════════════════════════════════
// AUTH
// ═══════════════════════════════════════
function openAuth(tab) {
  document.getElementById('auth-modal').classList.add('open');
  switchAuthTab(tab, document.querySelector(`.modal-tab:${tab==='login'?'first':'last'}-child`));
}
function closeAuth() { document.getElementById('auth-modal').classList.remove('open'); }

function switchAuthTab(tab, el) {
  document.querySelectorAll('.modal-tab').forEach(t=>t.classList.remove('active'));
  if(el) el.classList.add('active');
  document.getElementById('login-form').style.display=tab==='login'?'block':'none';
  document.getElementById('signup-form').style.display=tab==='signup'?'block':'none';
  document.getElementById('auth-title').textContent=tab==='login'?'Sign In':'Join AURA';
  // Reset to stage 1 when switching tabs
  if(tab==='login') {
    document.getElementById('login-stage1').style.display='block';
    document.getElementById('login-stage2').style.display='none';
    document.getElementById('login-error').textContent='';
    document.getElementById('login-otp-error').textContent='';
  } else {
    document.getElementById('signup-stage1').style.display='block';
    document.getElementById('signup-stage2').style.display='none';
    document.getElementById('signup-email-error').textContent='';
    document.getElementById('signup-error').textContent='';
  }
}

// ── LOGIN OTP FLOW ─────────────────────
async function requestLoginOtp() {
  const email=document.getElementById('login-email').value.trim();
  const pass=document.getElementById('login-pass').value;
  const err=document.getElementById('login-error');
  err.textContent='';
  
  if(!email || !pass) { err.textContent = 'Please enter email and password'; return; }
  if(!email.includes('@')) { err.textContent = 'Invalid email format'; return; }
  
  try {
    console.log('Requesting OTP for login...');
    const res = await fetch(`${API_BASE}/auth/login-request`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, password: pass })
    });
    const data = await res.json();
    console.log('OTP request response:', data);
    
    if(!res.ok) {
      err.textContent = data.message || 'Failed to send OTP. Please try again.';
      return;
    }
    
    // Store email for verification stage
    localStorage.setItem('login_email', email);
    
    // Move to stage 2
    document.getElementById('login-stage1').style.display='none';
    document.getElementById('login-stage2').style.display='block';
    showToast('✓ OTP sent to your email');
  } catch(e) {
    console.error('OTP request error:', e);
    err.textContent = 'Connection error: ' + e.message;
  }
}

async function verifyLoginOtp() {
  const email = localStorage.getItem('login_email');
  const otp = document.getElementById('login-otp').value.trim();
  const err = document.getElementById('login-otp-error');
  err.textContent='';
  
  if(!otp || otp.length !== 6) { 
    err.textContent = 'Please enter a valid 6-digit OTP'; 
    return; 
  }
  
  try {
    console.log('Verifying OTP...');
    const res = await fetch(`${API_BASE}/auth/login-verify`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, otp })
    });
    const data = await res.json();
    console.log('OTP verification response:', data);
    
    if(!res.ok) {
      err.textContent = data.message || 'OTP verification failed';
      return;
    }
    
    // Verify token received
    if(!data.token) {
      err.textContent = 'No authentication token received. Please contact support.';
      return;
    }
    
    // Set token and user
    setToken(data.token);
    const rememberMe = document.getElementById('remember-me').checked;
    if(rememberMe) {
      const expirationTime = Date.now() + (30 * 24 * 60 * 60 * 1000);
      localStorage.setItem('aura_token_exp', expirationTime.toString());
      localStorage.setItem('aura_remember_me', 'true');
    }
    
    const user = { id: data.id, name: data.name, email: data.email, role: data.role };
    setUser(user);
    localStorage.removeItem('login_email');
    closeAuth();
    renderGallery();
    showToast(`Welcome back, <span class="toast-gold">${user.name}</span>`);
  } catch(e) {
    console.error('OTP verification error:', e);
    err.textContent = 'Connection error: ' + e.message;
  }
}

function goBackToLoginStage1() {
  document.getElementById('login-stage1').style.display='block';
  document.getElementById('login-stage2').style.display='none';
  document.getElementById('login-otp').value='';
  document.getElementById('login-otp-error').textContent='';
}

// ── SIGNUP OTP FLOW ────────────────────
async function requestSignupOtp() {
  const email = document.getElementById('signup-email').value.trim();
  const err = document.getElementById('signup-email-error');
  err.textContent='';
  
  if(!email) { err.textContent = 'Please enter your email'; return; }
  if(!email.includes('@')) { err.textContent = 'Invalid email format'; return; }
  
  try {
    console.log('Requesting OTP for signup...');
    const res = await fetch(`${API_BASE}/auth/signup-request`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email })
    });
    const data = await res.json();
    console.log('Signup OTP request response:', data);
    
    if(!res.ok) {
      err.textContent = data.message || 'Failed to send OTP. Please try again.';
      return;
    }
    
    // Store email for verification stage
    localStorage.setItem('signup_email', email);
    
    // Move to stage 2
    document.getElementById('signup-stage1').style.display='none';
    document.getElementById('signup-stage2').style.display='block';
    showToast('✓ OTP sent to your email');
  } catch(e) {
    console.error('Signup OTP request error:', e);
    err.textContent = 'Connection error: ' + e.message;
  }
}

async function doSignupVerify() {
  const email = localStorage.getItem('signup_email');
  const name = document.getElementById('signup-name').value.trim();
  const otp = document.getElementById('signup-otp').value.trim();
  const pass = document.getElementById('signup-pass').value;
  const role = document.getElementById('signup-role').value;
  const err = document.getElementById('signup-error');
  err.textContent='';
  
  if(!name) { err.textContent = 'Please enter your name'; return; }
  if(!otp || otp.length !== 6) { err.textContent = 'Please enter a valid 6-digit OTP'; return; }
  if(pass.length < 6) { err.textContent = 'Password must be at least 6 characters'; return; }
  
  try {
    console.log('Verifying signup OTP...');
    const res = await fetch(`${API_BASE}/auth/signup-verify`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, email, otp, password: pass, role })
    });
    const data = await res.json();
    console.log('Signup verification response:', data);
    
    if(!res.ok) {
      err.textContent = data.message || 'Signup failed';
      return;
    }
    
    // Verify token received
    if(!data.token) {
      err.textContent = 'No authentication token received. Please contact support.';
      return;
    }
    
    // Set token and user
    setToken(data.token);
    const user = { id: data.id, name: data.name, email: data.email, role: data.role };
    setUser(user);
    localStorage.removeItem('signup_email');
    closeAuth();
    renderGallery();
    showToast(`Welcome to AURA, <span class="toast-gold">${name}</span>!`);
  } catch(e) {
    console.error('Signup verification error:', e);
    err.textContent = 'Connection error: ' + e.message;
  }
}

function goBackToSignupStage1() {
  document.getElementById('signup-stage1').style.display='block';
  document.getElementById('signup-stage2').style.display='none';
  document.getElementById('signup-otp').value='';
  document.getElementById('signup-name').value='';
  document.getElementById('signup-pass').value='';
  document.getElementById('signup-error').textContent='';
}

// Legacy functions for backward compatibility
async function doLogin() {
  // Redirects to new OTP flow
  await requestLoginOtp();
}

async function doSignup() {
  // Redirects to new OTP flow
  await requestSignupOtp();
}

function setUser(user) {
  currentUser=user;
  localStorage.setItem('aura_current',JSON.stringify(user));
  document.getElementById('nav-guest').style.display='none';
  document.getElementById('nav-auth').style.display='flex';
  document.getElementById('username-display').textContent=user.name;
  document.getElementById('role-badge').textContent=user.role;
  if(user.role==='ARTIST') {
    document.getElementById('nav-upload').style.display='inline';
  }
  updateCartUI();
}

function logout() {
  currentUser=null; cart=[];
  clearToken();
  localStorage.removeItem('aura_current');
  localStorage.removeItem('aura_cart');
  localStorage.removeItem('aura_token_exp');
  localStorage.removeItem('aura_remember_me');
  localStorage.removeItem('login_email');
  localStorage.removeItem('signup_email');
  document.getElementById('nav-guest').style.display='flex';
  document.getElementById('nav-auth').style.display='none';
  document.getElementById('nav-upload').style.display='none';
  document.getElementById('upload-section').style.display='none';
  updateCartUI();
  renderGallery();
  showToast('Signed out. See you again!');
}

// ═══════════════════════════════════════
// UPLOAD
// ═══════════════════════════════════════
function showUpload() {
  const s=document.getElementById('upload-section');
  s.style.display = s.style.display==='none'?'block':'none';
  if(s.style.display==='block') { try { s.scrollIntoView({behavior:'smooth'}); } catch(e) { s.scrollIntoView(); } }
}

function handleDragOver(e) { e.preventDefault(); document.getElementById('upload-zone').classList.add('dragover'); }
function handleDrop(e) {
  e.preventDefault();
  document.getElementById('upload-zone').classList.remove('dragover');
  if(e.dataTransfer.files[0]) processFile(e.dataTransfer.files[0]);
}
function handleFileSelect(e) { if(e.target.files[0]) processFile(e.target.files[0]); }
function processFile(file) {
  const reader=new FileReader();
  reader.onload=e=>{
    const prev=document.getElementById('upload-preview');
    prev.src=e.target.result; prev.style.display='block';
    uploadedImg=e.target.result;
  };
  reader.readAsDataURL(file);
}
let uploadedImg=null;

async function uploadArtwork() {
  if(!currentUser||currentUser.role!=='ARTIST') { showToast('Only artists can upload'); return; }
  if(apiConnectionFailed) { showToast('⚠ Backend is offline. Cannot upload at this time.'); return; }
  const title=document.getElementById('up-title').value.trim();
  const price=parseFloat(document.getElementById('up-price').value);
  const category=document.getElementById('up-category').value;
  const medium=document.getElementById('up-medium').value.trim();
  const desc=document.getElementById('up-desc').value.trim();
  
  if(!title||!price) { showToast('Please fill in title and price'); return; }
  if(title.length < 3) { showToast('Title must be at least 3 characters'); return; }
  if(price <= 0) { showToast('Price must be greater than 0'); return; }
  
  // Check for duplicate title in existing artworks
  const duplicateTitle = artworks.find(a => a.title.toLowerCase() === title.toLowerCase());
  if(duplicateTitle) { 
    showToast(`Artwork with title "${title}" already exists. Please use a unique title.`); 
    return; 
  }
  
  try {
    const fileInput = document.getElementById('file-input');
    if(!fileInput || !fileInput.files || !fileInput.files[0]) { 
      showToast('Please select an image file'); 
      return; 
    }
    
    const file = fileInput.files[0];
    // Validate file size (max 10MB)
    const maxSize = 10 * 1024 * 1024; // 10MB
    if(file.size > maxSize) {
      showToast('Image file is too large. Maximum size is 10MB.');
      return;
    }
    
    // Validate file type
    const validTypes = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];
    if(!validTypes.includes(file.type)) {
      showToast('Invalid file type. Please upload JPG, PNG, GIF, or WebP.');
      return;
    }
    
    const form = new FormData();
    form.append('title', title);
    form.append('price', price);
    form.append('category', category);
    form.append('medium', medium);
    form.append('description', desc);
    form.append('image', file);
    
    showToast('Uploading artwork...');
    const res = await fetch(`${API_BASE}/artworks`, {
      method: 'POST',
      headers: { 'Authorization': 'Bearer ' + getToken() },
      body: form
    });
    const data = await res.json();
    if(!res.ok) { showToast('Upload failed: ' + (data.message || 'Unknown error')); return; }
    
    // Clear form
    document.getElementById('up-title').value='';
    document.getElementById('up-price').value='';
    document.getElementById('up-medium').value='';
    document.getElementById('up-desc').value='';
    document.getElementById('upload-preview').style.display='none';
    fileInput.value='';
    uploadedImg=null;
    
    showToast(`<span class="toast-gold">${title}</span> published to gallery!`);
    renderGallery();
    const gallerySection = document.getElementById('gallery-section');
    if(gallerySection) gallerySection.scrollIntoView({behavior:'smooth'});
  } catch(e) { 
    showToast('Upload error: ' + e.message + ' (Backend may be offline)'); 
    console.error(e); 
  }
}

function saveArtworks() { localStorage.setItem('aura_artworks',JSON.stringify(artworks)); }

// ═══════════════════════════════════════
// UTILITIES
// ═══════════════════════════════════════
let toastTimer;
function showToast(msg) {
  const t=document.getElementById('toast');
  t.innerHTML=msg; t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer=setTimeout(()=>t.classList.remove('show'),3000);
}

function smoothScrollTo(id) {
  const el = document.getElementById(id);
  if(el) {
    try {
      el.scrollIntoView({behavior:'smooth'});
    } catch(e) {
      el.scrollIntoView();
    }
  }
}

window.addEventListener('resize',()=>{
  if(!renderer) return;
  const c=document.getElementById('viewer-canvas');
  const W=c.clientWidth,H=c.clientHeight;
  camera.aspect=W/H; camera.updateProjectionMatrix();
  renderer.setSize(W,H);
});

// ── VISIBILITY & CONNECTION MONITORING ──
document.addEventListener('visibilitychange', () => {
  if(document.hidden) {
    console.log('Page hidden');
  } else {
    console.log('Page visible again');
    // When user returns to tab, attempt reconnnection
    if(apiConnectionFailed && retryAttempts < MAX_RETRY_ATTEMPTS) {
      console.log('User returned to page. Attempting reconnection...');
      retryAttempts = 0; // Reset counter
      renderGallery();
    }
  }
});

// Monitor online/offline status
window.addEventListener('online', () => {
  console.log('Connection restored');
  if(apiConnectionFailed) {
    showToast('✓ Connection restored. Refreshing data...');
    retryAttempts = 0;
    renderGallery();
  }
});

window.addEventListener('offline', () => {
  console.log('Connection lost');
  showToast('⚠ You are offline. Using cached data.');
});

// ── INIT ──────────────────────────────
if(currentUser) {
  setUser(currentUser);
  if(getToken()) {
    // Token exists but verify it's still valid
    const exp = localStorage.getItem('aura_token_exp');
    if(exp && Date.now() > parseInt(exp)) {
      console.log('Token expired. Logging out user.');
      clearToken();
      logout();
    }
  }
}

// Load initial artworks
renderGallery();

// Periodic health check to ensure backend is still running (every 30 seconds)
setInterval(() => {
  if(!apiConnectionFailed) return; // Only check if we're already in failed state
  
  fetch(`${API_BASE}/artworks?limit=1`, { method: 'HEAD' })
    .then(res => {
      if(res.ok && apiConnectionFailed) {
        console.log('Backend is back online');
        retryAttempts = 0;
        renderGallery();
      }
    })
    .catch(() => {
      // Still offline, do nothing
    });
}, 30000);
</script>
</body>
</html>
